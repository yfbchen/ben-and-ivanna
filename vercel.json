{
  "rewrites": [
    { "source": "/assets/(.*)", "destination": "/assets/$1" },
    { "source": "/calendar.png", "destination": "/calendar.png" },
    { "source": "/robots.txt", "destination": "/robots.txt" },
    { "source": "/sitemap.xml", "destination": "/sitemap.xml" },
    { "source": "/favicon.ico", "destination": "/favicon.ico" },
    { "source": "/favicon.svg", "destination": "/favicon.svg" },
    { "source": "/favicon-16.png", "destination": "/favicon-16.png" },
    { "source": "/favicon-32.png", "destination": "/favicon-32.png" },
    { "source": "/favicon-180.png", "destination": "/favicon-180.png" },
    { "source": "/apple-touch-icon.png", "destination": "/favicon-180.png" },
    { "source": "/vite.svg", "destination": "/vite.svg" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
